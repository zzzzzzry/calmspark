---
const currentYear = new Date().getFullYear();
---

<footer class="py-12 mt-auto border-t border-white/10 bg-transparent">
  <div class="max-w-[1600px] mx-auto px-4 sm:px-6 lg:px-8 flex flex-col md:flex-row justify-between items-center text-sm text-white/60">
    <div class="flex flex-col md:flex-row items-center gap-4">
      <span class="font-bold text-white/90">CalmSpark</span>
      <span class="hidden md:inline text-white/20">|</span>
      <p>&copy; {currentYear} 保留所有权利。</p>
    </div>
    <div class="flex space-x-8 mt-6 md:mt-0">
      <a href="https://github.com" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors hover:scale-110 transform duration-300">GitHub</a>
      <a href="https://twitter.com" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors hover:scale-110 transform duration-300">Twitter</a>
      <a href="/rss.xml" class="hover:text-white transition-colors hover:scale-110 transform duration-300">RSS</a>
    </div>
  </div>
</footer>
