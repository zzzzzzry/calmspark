---
const pathname = new URL(Astro.request.url).pathname;
const base = '/calmspark';
const links = [
  { href: base + '/', label: '封面' },
  { href: base + '/home', label: '首页' },
  { href: base + '/works', label: '作品' },
  { href: base + '/resume', label: '简历' },
  { href: base + '/chat', label: 'AI 对话' },
  { href: base + '/about', label: '关于' },
];
---

<header class="fixed top-0 z-50 w-full">
  <div class="absolute inset-0 bg-gradient-to-b from-black/60 to-transparent pointer-events-none opacity-80"></div>

  <div class="relative max-w-[1600px] mx-auto px-4 sm:px-6 lg:px-8 h-24 flex items-center justify-between">
    <a href="/calmspark/home" class="group flex items-center gap-3">
      <div class="relative w-10 h-10 rounded-full bg-white/10 flex items-center justify-center text-white font-bold backdrop-blur-sm border border-white/20 group-hover:bg-white/20 transition-all duration-300">
        <span class="text-lg">CS</span>
      </div>
      <span class="text-xl font-bold text-white tracking-tight drop-shadow-md">
        CalmSpark
      </span>
    </a>

    <nav class="hidden md:flex items-center gap-2">
      {links.map(({ href, label }) => {
        const isActive = href === base + '/' ? pathname === base + '/' : pathname.startsWith(href);
        return (
        <a
          href={href}
          class={`relative px-5 py-2 rounded-full text-sm font-medium transition-all duration-300 group ${isActive ? 'text-white bg-white/10' : 'text-white/70 hover:text-white'}`}
          aria-current={isActive ? 'page' : undefined}
        >
          {label}
          <span class={`absolute bottom-1.5 left-1/2 -translate-x-1/2 h-0.5 bg-white/80 rounded-full transition-all duration-300 ${isActive ? 'w-4' : 'w-0 group-hover:w-4'}`}></span>
        </a>
      )})}
</nav>
</header>
