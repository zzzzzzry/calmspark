---
const pathname = new URL(Astro.request.url).pathname;
const links = [
  { href: '/', label: '封面' },
  { href: '/home', label: '首页' },
  { href: '/works', label: '作品' },
  { href: '/resume', label: '简历' },
  { href: '/chat', label: 'AI 对话' },
  { href: '/about', label: '关于' },
];
---

<header class="fixed top-0 z-50 w-full">
  <!-- Minimal Gradient for text readability, no glass blocking -->
  <div class="absolute inset-0 bg-gradient-to-b from-black/60 to-transparent pointer-events-none opacity-80"></div>

  <div class="relative max-w-[1600px] mx-auto px-4 sm:px-6 lg:px-8 h-24 flex items-center justify-between">
    <a href="/home" class="group flex items-center gap-3">
      <div class="relative w-10 h-10 rounded-full bg-white/10 flex items-center justify-center text-white font-bold backdrop-blur-sm border border-white/20 group-hover:bg-white/20 transition-all duration-300">
        <span class="text-lg">CS</span>
      </div>
      <span class="text-xl font-bold text-white tracking-tight drop-shadow-md">
        CalmSpark
      </span>
    </a>

    <nav class="hidden md:flex items-center gap-2">
      {links.map(({ href, label }) => {
        const isActive = href === '/' ? pathname === '/' : (href === '/home' ? pathname === '/home' : pathname.startsWith(href));
        return (
        <a
          href={href}
          class={`relative px-5 py-2 rounded-full text-sm font-medium transition-all duration-300 group ${isActive ? 'text-white bg-white/10' : 'text-white/70 hover:text-white'}`}
          aria-current={isActive ? 'page' : undefined}
        >
          {label}
          {/* Hover Indicator: Bottom Border expanding */}
          <span class={`absolute bottom-1.5 left-1/2 -translate-x-1/2 h-0.5 bg-white/80 rounded-full transition-all duration-300 ${isActive ? 'w-4' : 'w-0 group-hover:w-4'}`}></span>
        </a>
      )})}
    </nav>

    <div class="md:hidden">
      <button id="mobile-menu-btn" class="p-2 rounded-full text-white hover:bg-white/10 transition-colors z-50 relative">
        <span class="sr-only">菜单</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
      </button>
    </div>

    <!-- Mobile Menu Overlay -->
    <div id="mobile-menu" class="fixed inset-0 bg-black/90 backdrop-blur-xl z-40 transform translate-x-full transition-transform duration-300 md:hidden flex flex-col items-center justify-center space-y-8">
      {links.map(({ href, label }) => (
        <a
          href={href}
          class="text-2xl font-bold text-white/80 hover:text-white hover:scale-110 transition-all duration-300"
        >
          {label}
        </a>
      ))}
    </div>
  </div>
</header>

<script>
  function setupMobileMenu() {
    const menuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    let isOpen = false;

    // Remove old listeners if any (though usually DOM is replaced)
    // But for safety in case of persistence
    
    const toggleMenu = () => {
      isOpen = !isOpen;
      if (isOpen) {
        mobileMenu?.classList.remove('translate-x-full');
      } else {
        mobileMenu?.classList.add('translate-x-full');
      }
    };

    menuBtn?.addEventListener('click', toggleMenu);

    // Close menu when clicking a link
    const links = mobileMenu?.querySelectorAll('a');
    links?.forEach(link => {
      link.addEventListener('click', () => {
        isOpen = false;
        mobileMenu?.classList.add('translate-x-full');
      });
    });
  }

  // Run on initial load
  setupMobileMenu();

  // Run on View Transition navigation
  document.addEventListener('astro:after-swap', setupMobileMenu);
</script>
