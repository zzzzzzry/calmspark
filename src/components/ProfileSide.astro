---
import GlassCard from './GlassCard.astro';
import SocialLinks from './SocialLinks.astro';
import { MapPin, Briefcase, GraduationCap } from 'lucide-react';
---

<GlassCard class="h-full p-8 flex flex-col items-center text-center relative overflow-hidden group" hoverEffect={false}>
  <!-- Decorative background gradient -->
  <div class="absolute inset-0 bg-gradient-to-b from-primary-500/10 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>

  <div class="relative w-32 h-32 mb-6 group-hover:scale-105 transition-transform duration-500">
    <div class="absolute inset-0 rounded-full bg-gradient-to-tr from-primary-400 to-secondary-400 blur-lg opacity-40 animate-pulse"></div>
    <div class="relative w-full h-full rounded-full overflow-hidden border-2 border-white/50 dark:border-white/10 shadow-xl">
      <img src="/icon.png" alt="Avatar" class="w-full h-full object-cover" />
    </div>
    <div class="absolute bottom-1 right-1 w-6 h-6 bg-green-500 border-4 border-white dark:border-black rounded-full" title="Online"></div>
  </div>
  
  <div class="relative z-10">
    <h1 class="text-3xl font-bold text-primary-900 dark:text-white mb-2 tracking-tight">CalmSpark</h1>
    <p class="text-sm font-medium text-transparent bg-clip-text bg-gradient-to-r from-primary-600 to-secondary-600 dark:from-primary-300 dark:to-secondary-300 mb-6">
      全栈开发者 & UI 设计师
    </p>

    <div class="flex flex-wrap justify-center gap-2 mb-8">
      <span class="px-3 py-1 text-xs font-medium rounded-full bg-primary-50 dark:bg-white/5 text-primary-700 dark:text-primary-300 border border-primary-100 dark:border-white/10">
        🚀 探索中
      </span>
      <span class="px-3 py-1 text-xs font-medium rounded-full bg-secondary-50 dark:bg-white/5 text-secondary-700 dark:text-secondary-300 border border-secondary-100 dark:border-white/10">
        ✨ 追求极致
      </span>
    </div>

    <div class="w-full space-y-4 pt-6 border-t border-dashed border-secondary-200 dark:border-white/10 text-left">
      <div class="flex items-center justify-between text-sm group/item hover:bg-black/5 dark:hover:bg-white/5 p-2 rounded-lg transition-colors cursor-default">
        <div class="flex items-center gap-3 text-secondary-700 dark:text-white font-medium">
          <Briefcase size={16} class="text-secondary-700 dark:text-white" />
          <span>状态</span>
        </div>
        <span class="font-medium text-primary-900 dark:text-white">自由职业</span>
      </div>
      <div class="flex items-center justify-between text-sm group/item hover:bg-black/5 dark:hover:bg-white/5 p-2 rounded-lg transition-colors cursor-default">
        <div class="flex items-center gap-3 text-secondary-700 dark:text-white font-medium">
          <GraduationCap size={16} class="text-secondary-700 dark:text-white" />
          <span>专业</span>
        </div>
        <span class="font-medium text-primary-900 dark:text-white">计算机科学</span>
      </div>
      <div class="flex items-center justify-between text-sm group/item hover:bg-black/5 dark:hover:bg-white/5 p-2 rounded-lg transition-colors cursor-default">
        <div class="flex items-center gap-3 text-secondary-700 dark:text-white font-medium">
          <MapPin size={16} class="text-secondary-700 dark:text-white" />
          <span>坐标</span>
        </div>
        <span class="font-medium text-primary-900 dark:text-white">上海 · 中国</span>
      </div>
    </div>
  </div>

  <div class="mt-8 w-full">
    <SocialLinks />
  </div>
</GlassCard>
