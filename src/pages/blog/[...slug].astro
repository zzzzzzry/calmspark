---
import { type CollectionEntry, getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GlassCard from '../../components/GlassCard.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.slug },
		props: post,
	}));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await post.render();
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <GlassCard class="p-8 md:p-12 animate-fade-in" hoverEffect={false}>
    <article class="prose prose-lg dark:prose-invert mx-auto">
      <div class="mb-10 text-center border-b border-white/10 pb-8">
         <div class="text-sm text-secondary-500 mb-4">
            <time datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString('zh-CN', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })}
            </time>
         </div>
         <h1 class="text-3xl md:text-5xl font-bold text-primary-900 dark:text-white mb-6 !leading-tight">{post.data.title}</h1>
         {post.data.heroImage && <img width={1020} height={510} src={post.data.heroImage} alt="" class="rounded-xl shadow-2xl w-full" />}
      </div>
      <div class="prose-headings:font-sans prose-a:text-primary-600 dark:prose-a:text-primary-400">
        <Content />
      </div>
    </article>
  </GlassCard>
</BaseLayout>
