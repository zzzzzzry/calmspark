---
import BaseLayout from '../layouts/BaseLayout.astro';
import { ArrowRight, ChevronDown, ChevronUp, Sparkles } from 'lucide-react';

const base = '/calmspark';

const sections = [
  {
    title: "文字，思考的沉淀。",
    desc: "在这个信息碎片化的时代，我选择用文字记录深度思考。不追求流量，只求思想的共鸣与沉淀。",
    image: base + "/school1.jpg",
    align: "center",
    theme: "light"
  },
  {
    title: "代码，构建世界。",
    desc: "每一行代码都是逻辑的诗篇。从后端架构到前端交互，探索全栈开发的无限可能，创造有温度的数字产品。",
    image: base + "/zhi1.jpg",
    align: "left",
    theme: "gray",
    imagePosition: "90% 60%"
  },
  {
    title: "生活，不仅是远方。",
    desc: "放慢脚步，感受城市的脉搏。在北京的街头巷尾，发现那些被忽略的平凡美好。",
    image: base + "/beijing1.jpg",
    align: "right",
    theme: "light"
  }
];
---

<BaseLayout title="CalmSpark">
  <!-- Scroll Snap Container -->
  <div class="w-full flex flex-col items-center">
    
    <!-- Hero Section Content (Floating over global background) -->
    <section id="hero" class="w-full min-h-[80vh] flex flex-col items-center justify-center pt-20 pb-10 px-4 relative text-center">
      
      <div class="animate-slide-up space-y-6 max-w-4xl mx-auto z-10 relative flex flex-col items-center">
         
         <!-- Avatar -->
         <div class="w-24 h-24 rounded-full overflow-hidden border-4 border-white/50 shadow-xl mb-4 backdrop-blur-sm">
            <img src={base + "/icon.png"} alt="Avatar" class="w-full h-full object-cover" />
         </div>

         <h2 class="text-sm font-bold tracking-[0.2em] text-white/80 uppercase mb-4 drop-shadow-md">Personal Blog</h2>
         <h1 class="text-5xl md:text-7xl lg:text-8xl font-bold tracking-tight text-white leading-[1.1] drop-shadow-lg">
            设计，<br class="md:hidden" />
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-purple-400">不止于见。</span>
         </h1>
         <p class="text-lg md:text-xl text-white/90 max-w-2xl mx-auto leading-relaxed font-light drop-shadow-md">
            探索全栈开发的无限可能。以极简美学重塑数字体验，<br class="hidden md:block"/>让每一行代码都富有生命力。
         </p>
         
         <div class="pt-8 flex flex-col sm:flex-row gap-4 justify-center items-center">
            <a href={base + "/chat"} class="px-8 py-3 rounded-full bg-gradient-to-r from-purple-600 to-pink-600 hover:from-purple-500 hover:to-pink-500 text-white font-medium transition-all shadow-lg hover:shadow-purple-600/30 hover:scale-105 flex items-center gap-2 backdrop-blur-md border border-white/10">
               <Sparkles size={18} /> AI 助手
            </a>
            <a href={base + "/blog"} class="px-8 py-3 rounded-full bg-blue-600 hover:bg-blue-700 text-white font-medium transition-all shadow-lg hover:shadow-blue-600/30 hover:scale-105 flex items-center gap-2">
               阅读博客 <ArrowRight size={18} />
            </a>
            <a href="#section-0" class="px-8 py-3 rounded-full bg-white/20 hover:bg-white/30 text-white font-medium transition-all border border-white/30 hover:scale-105">
               了解更多
            </a>
         </div>
      </div>
    </section>

    <!-- Product Features Sections -->
    <!-- Added backdrop-blur and semi-transparent backgrounds to sections to make text readable over global bg -->
    <div id="features" class="w-full flex flex-col gap-8 py-12">
      
      {sections.map((section, index) => (
        <section id={`section-${index}`} class={`w-full py-24 md:py-32 px-6 flex flex-col md:flex-row items-center justify-center gap-12 md:gap-24 overflow-hidden rounded-3xl relative`}>
          
          {/* Layout Logic: Centered vs Left/Right */}
          {section.align === 'center' ? (
             <div class="flex flex-col items-center text-center max-w-5xl mx-auto">
               <h2 class="text-4xl md:text-6xl font-bold text-white mb-6 leading-tight whitespace-pre-line drop-shadow-md">
                 {section.title}
               </h2>
               <p class="text-lg text-white/80 max-w-2xl mb-12 leading-relaxed font-light">
                 {section.desc}
               </p>
               <div class="w-full relative group">
                  <div class="absolute inset-0 bg-blue-500/20 blur-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-700 rounded-full"></div>
                  <img 
                    src={section.image} 
                    alt={section.title} 
                    style={{ objectPosition: section.imagePosition || 'center' }}
                    class="relative z-10 w-full aspect-video object-cover rounded-2xl md:rounded-[2rem] shadow-xl transform transition-transform duration-700 hover:scale-[1.02]"
                  />
               </div>
             </div>
          ) : (
            <div class={`flex flex-col md:flex-row items-center gap-12 md:gap-24 max-w-7xl mx-auto w-full ${section.align === 'right' ? 'md:flex-row-reverse' : ''}`}>
               <div class="flex-1 space-y-6 md:px-8">
                 <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight whitespace-pre-line drop-shadow-md">
                   {section.title}
                 </h2>
                 <p class="text-lg text-white/80 leading-relaxed max-w-lg font-light">
                   {section.desc}
                 </p>
                 <div class="pt-4">
                   <a href={base + "/gallery"} class="inline-flex items-center text-blue-400 font-medium hover:gap-2 transition-all hover:text-blue-300">
                     查看详情 <ArrowRight size={18} className="ml-1" />
                   </a>
                 </div>
               </div>
               <div class="flex-1 w-full">
                  <img 
                    src={section.image} 
                    alt={section.title} 
                    style={{ objectPosition: section.imagePosition || 'center' }}
                    class="w-full aspect-video object-cover rounded-2xl md:rounded-[2.5rem] shadow-2xl hover:shadow-3xl transition-shadow duration-500"
                  />
               </div>
            </div>
          )}

          {/* Next Section Arrow - Removed */}
        </section>
      ))}

    </div>

    <!-- Final CTA Section -->
    <section id="contact" class="w-full py-32 mt-12 text-white text-center px-4 relative overflow-hidden rounded-3xl border border-white/10">
       <div class="absolute inset-0 bg-black/60 z-0"></div>
       <img src={base + "/beijing2.jpg"} alt="Contact Background" class="absolute inset-0 w-full h-full object-cover -z-10" />
       
       <div class="relative z-10 max-w-3xl mx-auto space-y-8">
          <h2 class="text-4xl md:text-6xl font-bold drop-shadow-lg">准备好开始了吗？</h2>
          <p class="text-xl text-white/80 font-light">无论是合作项目，还是技术交流，<br/>我都期待与你的每一次对话。</p>
          <a href="mailto:hi@calmspark.com" class="inline-block px-10 py-4 rounded-full bg-white text-black font-bold text-lg hover:scale-105 transition-transform shadow-[0_0_20px_rgba(255,255,255,0.3)]">
             联系我
          </a>
       </div>
    </section>

    <!-- Global Fixed Scroll Arrow -->
    <div id="scroll-arrow" class="fixed bottom-0 left-0 right-0 z-50 flex justify-center pointer-events-none transition-opacity duration-300">
      <a href="#" aria-label="Scroll to next section" class="flex items-end justify-center w-full max-w-lg h-32 pb-8 text-white/70 hover:text-white transition-colors cursor-pointer pointer-events-auto group">
         <div class="animate-bounce">
           <ChevronDown size={32} />
         </div>
      </a>
    </div>

    <!-- End of Page Indicator / Back to Top -->
     <div id="end-indicator" class="fixed bottom-0 left-0 right-0 z-50 flex justify-center pointer-events-none opacity-0 transition-opacity duration-300">
         <button id="back-to-top" class="flex flex-col items-center justify-end w-full max-w-lg h-32 pb-8 text-white/70 hover:text-white transition-colors cursor-pointer pointer-events-auto group">
            <div class="animate-bounce flex flex-col items-center gap-2">
                <ChevronUp size={32} />
                <span class="text-sm font-light tracking-widest uppercase">回到顶部</span>
            </div>
         </button>
     </div>
 
  </div>
</BaseLayout>

<style>
  html {
    scroll-behavior: smooth;
  }
</style>

<script>
  // Client-side script to handle scroll arrow logic
  const arrowContainer = document.getElementById('scroll-arrow');
   const arrowLink = arrowContainer?.querySelector('a');
   const endIndicator = document.getElementById('end-indicator');
   const backToTopBtn = document.getElementById('back-to-top');
 
   function getSections() {
      return ['hero', ...Array.from(document.querySelectorAll('[id^="section-"]')).map(el => el.id), 'contact'];
   }
 
   function scrollToNextSection(e) {
     e.preventDefault();
     const sections = getSections();
     
     // Find the next section to scroll to
     let targetId = null;
     const threshold = window.innerHeight * 0.3; // 30% of viewport height
     
     for (const id of sections) {
         const el = document.getElementById(id);
         if (el) {
             const rect = el.getBoundingClientRect();
             // If the section's top is significantly below the viewport top,
             // it is considered the "next" section to snap to.
             // Using a larger threshold (30% height) avoids snapping to the current section
             // if it's just slightly misaligned (e.g. due to header offset or anchor jump).
             if (rect.top > threshold) {
                 targetId = id;
                 break;
             }
         }
     }

     if (targetId) {
         const targetEl = document.getElementById(targetId);
         if (targetEl) {
             targetEl.scrollIntoView({ behavior: 'smooth' });
         }
     }
   }

   function scrollToTop() {
       window.scrollTo({ top: 0, behavior: 'smooth' });
   }
 
   function updateArrowVisibility() {
     if (!arrowContainer || !endIndicator || !backToTopBtn || !arrowLink) return;
 
     const scrollY = window.scrollY;
     const docHeight = document.documentElement.scrollHeight;
     const winHeight = window.innerHeight;
 
     // Check if we are at the bottom
     // Use a small buffer (e.g. 10px) to account for browser calculation differences
     const isBottom = scrollY + winHeight >= docHeight - 10;
 
     if (isBottom) {
         arrowContainer.style.opacity = '0';
         arrowContainer.style.visibility = 'hidden'; // Hide completely
         
         endIndicator.style.opacity = '1';
         endIndicator.style.visibility = 'visible'; // Show
         
         // Explicitly handle pointer events for safety
         backToTopBtn.style.pointerEvents = 'auto';
         arrowLink.style.pointerEvents = 'none';
     } else {
         arrowContainer.style.opacity = '1';
         arrowContainer.style.visibility = 'visible'; // Show
         
         endIndicator.style.opacity = '0';
         endIndicator.style.visibility = 'hidden'; // Hide completely to prevent overlapping clicks
         
         // Explicitly handle pointer events
         backToTopBtn.style.pointerEvents = 'none';
         arrowLink.style.pointerEvents = 'auto';
     }
   }
 
   // Bind click event
   if (arrowLink) {
       arrowLink.addEventListener('click', scrollToNextSection);
   }
   
   if (backToTopBtn) {
       backToTopBtn.addEventListener('click', scrollToTop);
   }
 
   // Initial check
   setTimeout(updateArrowVisibility, 100);

  // Listen for scroll
  window.addEventListener('scroll', () => {
    requestAnimationFrame(updateArrowVisibility);
  });
  
  // Also update on resize
  window.addEventListener('resize', updateArrowVisibility);
</script>
